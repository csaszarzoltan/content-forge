# ContentForge Environment Variables
# Copy this file to .env and fill in values.

# === Required ===

# PostgreSQL connection string (auto-set by Railway Postgres addon)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/contentforge

# OpenAI API key for content generation
LLM_API_KEY=sk-your-api-key-here

# Application secret for signing/session
SECRET_KEY=change-me-to-a-random-32-char-string

# === Optional ===

# LLM model to use (default: gpt-4o)
# LLM_MODEL=gpt-4o

# LLM provider name (default: openai)
# LLM_PROVIDER=openai

# Custom LLM API base URL (for proxies)
# LLM_BASE_URL=https://api.openai.com/v1

# Deployment environment (default: development)
# ENVIRONMENT=production

# CORS origins, comma-separated (default: *)
# CORS_ORIGINS=*

# Enable LLM connectivity check in health endpoint (default: false)
# HEALTH_CHECK_LLM=false
